  current_block=""
  current_block_start=0
  job_index=1
  line_no=0

  while IFS= read -r line || [[ -n "$line" ]]; do
    ((line_no++))
    if [[ "$line" =~ ^#\ \[(XEMI-ID|CronJob-ID)\]:\ (.+) ]]; then
      [[ -z "$current_block" ]] && current_block_start="$line_no"
      current_block="$line"
      job_names[$job_index]="${BASH_REMATCH[2]}"
    elif [[ "$line" =~ ^# ]]; then
      [[ -z "$current_block" ]] && current_block_start="$line_no"
      current_block+=$'\n'$line
    elif is_env_line "$line" || [[ -z "$line" ]]; then
      current_block=""
      current_block_start=0
    elif is_cron_job_line "$line"; then
      schedule_part=$(cron_schedule_part "$line")
      command_part=$(cron_command_part "$line")
      log_path=$(extract_log_path "$command_part")

      job_lines[$job_index]="$line"
      job_blocks[$job_index]="$current_block"
      job_logs[$job_index]="$log_path"
      job_meta[$job_index]="$current_block"
      job_start_lines[$job_index]="${current_block_start:-$line_no}"
      [[ "${job_start_lines[$job_index]}" -eq 0 ]] && job_start_lines[$job_index]="$line_no"
      job_line_numbers[$job_index]="$line_no"
      current_block=""
      current_block_start=0
      ((job_index++))
    else
