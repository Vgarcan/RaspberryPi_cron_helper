      current_block_start=0
    fi
  done <"$cron_raw"

  if [[ "${#job_lines[@]}" -eq 0 ]]; then
    echo -e "${YELLOW}No cron jobs found for user $REAL_USER.${RESET}"
    echo
    read -p "Press [Enter] to return..." pause
    return
  fi

  echo
  for index in $(printf '%s\n' "${!job_lines[@]}" | sort -n); do
    echo -e "${CYAN}Job #$index${RESET}"
    [[ -n "${job_blocks[$index]}" ]] && echo -e "  ${YELLOW}${job_blocks[$index]//$'\n'/$'\n  '}"
    echo -e "  ${YELLOW}Schedule:${RESET} $(cron_schedule_part "${job_lines[$index]}")"
    echo -e "  ${MAGENTA}Command: ${RESET}$(cron_command_part "${job_lines[$index]}")"
    if [[ -n "${job_logs[$index]}" ]]; then
      echo -e "  ${GREEN}Log file:${RESET} ${job_logs[$index]}"
    else
      echo -e "  ${RED}Log file:${RESET} No log detected"
    fi
    echo -e "${CYAN}--------------------------------------------------${RESET}"
  done

  echo
  echo -e "${MAGENTA}[C] Cancel${RESET}"
  read -p "Enter the job number or CronJob-ID to delete: " choice
  [[ "$choice" =~ ^[Cc]$ ]] && return

  selected_index=""
  if [[ "$choice" =~ ^[0-9]+$ ]]; then
    selected_index="$choice"
  else
    for i in "${!job_names[@]}"; do
      if [[ "${job_names[$i],,}" == "${choice,,}" ]]; then
        selected_index="$i"
        break
      fi
    done
  fi

  if [[ -z "$selected_index" ]] || [[ -z "${job_lines[$selected_index]}" ]]; then
    echo -e "${RED}Invalid selection.${RESET}"
    read -p "Press [Enter] to return..." pause
    return
  fi

  echo
  echo -e "${YELLOW}You selected to delete:${RESET}"
  [[ -n "${job_blocks[$selected_index]}" ]] && echo -e "${job_blocks[$selected_index]}"
  echo -e "${CYAN}${job_lines[$selected_index]}${RESET}"
  echo
  read -p "Are you sure you want to delete this cron job? (Y/N): " confirm1
  if [[ "$confirm1" =~ ^[Yy]$ ]]; then
    read -p "Please confirm again. Delete this cron job? (Y/N): " confirm2
    if [[ "$confirm2" =~ ^[Yy]$ ]]; then
      : >"$cron_updated"
      line_no=0
      skip_start="${job_start_lines[$selected_index]}"
      skip_until="${job_line_numbers[$selected_index]}"
      while IFS= read -r line || [[ -n "$line" ]]; do
        ((line_no++))
        (( line_no >= skip_start && line_no <= skip_until )) && continue
        printf '%s\n' "$line" >>"$cron_updated"
      done <"$cron_raw"

      write_crontab_for_user "$REAL_USER" "$cron_updated"
      echo
      echo -e "${GREEN}Cron job deleted successfully.${RESET}"
      log_action "deleted cron job for $REAL_USER id='${job_names[$selected_index]:-unnamed}' schedule='$(cron_schedule_part "${job_lines[$selected_index]}")'"
    else
      echo -e "${CYAN}Deletion cancelled.${RESET}"
      log_action "deletion cancelled for $REAL_USER job='$selected_index'"
    fi
  else
    echo -e "${CYAN}Deletion cancelled.${RESET}"
    log_action "deletion cancelled for $REAL_USER job='$selected_index'"
  fi

  read -p "Press [Enter] to return..." pause
}


